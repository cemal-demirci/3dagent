# Gateway URL (build-time — requires `npm run build` after changes)
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:18789

# Debug UI
DEBUG=true

# App server
# PORT=3000
# HOST=127.0.0.1

# Optional: required only for public/remote deployments
# STUDIO_ACCESS_TOKEN=

# Demo gateway (npm run dev ile otomatik başlar)
# DEMO_ADAPTER_PORT=18789

# Durum dizini (varsayılan: ~/.claw3d)
# CLAW3D_STATE_DIR=~/.claw3d

# AI Provider API Keys (ortam değişkeninden otomatik yüklenir)
# En az birini ayarlamanız yeterli — ajanlar yapılandırılmış provider'ı kullanır.
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...

# Rate limiting (sadece /api/* route'larına uygulanır)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=120

# Loglama seviyesi: debug, info, warn, error
# LOG_LEVEL=info

# Optional: voice features (transkripsiyon için GROQ_API_KEY gerekli)
# GROQ_API_KEY=gsk_...
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
